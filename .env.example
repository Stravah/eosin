EOSIN_MODAL_APP_NAME=eosin-glm-ocr
EOSIN_MODAL_GPU=A100-80GB
EOSIN_MODAL_MAX_CONTAINERS=1
EOSIN_MODAL_MAX_INPUTS=32
EOSIN_MODAL_TARGET_INPUTS=32
EOSIN_MODAL_SCALEDOWN_WINDOW=300
EOSIN_MODAL_TIMEOUT=1800
EOSIN_MODAL_MEMORY_MIB=40960

EOSIN_MODAL_VLLM_PORT=8000
EOSIN_MODAL_VLLM_MODEL=zai-org/GLM-OCR
EOSIN_MODAL_SERVED_MODEL_NAME=default
EOSIN_MODAL_VLLM_MAX_MODEL_LEN=22480
EOSIN_MODAL_VLLM_GPU_MEMORY_UTILIZATION=0.90
EOSIN_MODAL_VLLM_MAX_NUM_SEQS=192
EOSIN_MODAL_VLLM_MAX_BATCHED_TOKENS=32768
EOSIN_MODAL_VLLM_SPECULATIVE_CONFIG={"method": "mtp", "num_speculative_tokens": 1}

EOSIN_PARSER_BASE_URL=https://<workspace>--bank-parser.modal.run
